generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── IDENTITY ───────────────────────────────────────────────────────────

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  passwordHash  String?
  role          UserRole @default(USER)
  isActive      Boolean  @default(true)
  isSuspended   Boolean  @default(false)
  lastLoginAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  profile       Profile?
  communities   Community[]      @relation("CommunityOwner")
  memberships   CommunityMember[]
  listings      Listing[]
  requests      Request[]        @relation("Requester")
  messagesSent  Message[]        @relation("MessageSender")
  reviews       Review[]         @relation("ReviewAuthor")
  reviewsOf     Review[]         @relation("ReviewSubject")
  verifications Verification[]
  reports       Report[]         @relation("Reporter")
  reportedBy    Report[]         @relation("ReportedUser")
  notifications Notification[]
  savedListings SavedListing[]
  skills        UserSkill[]
  badges        UserBadge[]
  invitesSent   Invite[]         @relation("InviteSender")
  invitesReceived Invite[]       @relation("InviteRecipient")
}

enum UserRole {
  USER
  MODERATOR
  ADMIN
}

model Profile {
  id            String   @id @default(uuid())
  userId        String   @unique
  displayName   String
  bio           String?
  avatarUrl     String?
  coverUrl      String?
  latitude      Float?
  longitude     Float?
  city          String?
  region        String?
  country       String?
  website       String?
  phone         String?
  isPublic      Boolean  @default(true)
  trustScore    Float    @default(0)
  responseRate  Float    @default(0)
  responseTime  Int?     // avg minutes
  joinReason    String?
  interests     String[] @default([])
  languages     String[] @default([])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserSkill {
  id        String @id @default(uuid())
  userId    String
  name      String
  level     SkillLevel @default(BEGINNER)

  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

model UserBadge {
  id        String   @id @default(uuid())
  userId    String
  type      BadgeType
  awardedAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum BadgeType {
  VERIFIED_ID
  VERIFIED_EMAIL
  VERIFIED_PHONE
  TRUSTED_HOST
  TRUSTED_SEEKER
  COMMUNITY_BUILDER
  EARLY_ADOPTER
  TOP_REVIEWER
  AMBASSADOR
  SUPER_HOST
}

// ─── COMMUNITIES ────────────────────────────────────────────────────────

model Community {
  id            String   @id @default(uuid())
  name          String
  slug          String   @unique
  description   String?
  longDescription String?
  avatarUrl     String?
  coverUrl      String?
  latitude      Float?
  longitude     Float?
  city          String?
  region        String?
  country       String?
  isOnline      Boolean  @default(false)
  isVerified    Boolean  @default(false)
  isPublic      Boolean  @default(true)
  category      CommunityCategory @default(GENERAL)
  tags          String[] @default([])
  rules         String?
  ownerId       String
  memberCount   Int      @default(1)
  listingCount  Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  owner         User     @relation("CommunityOwner", fields: [ownerId], references: [id])
  memberships   CommunityMember[]
  listings      Listing[]
  matches       Match[]
  reports       Report[] @relation("ReportedCommunity")
  events        Event[]
  announcements Announcement[]
}

enum CommunityCategory {
  GENERAL
  PERMACULTURE
  URBAN_FARMING
  ECO_VILLAGE
  HOMESTEAD
  FOOD_FOREST
  COMMUNITY_GARDEN
  REGENERATIVE_AG
  SEED_SAVING
  COOPERATIVE
  LAND_TRUST
  CONSERVATION
}

model CommunityMember {
  id          String        @id @default(uuid())
  communityId String
  userId      String
  role        CommunityRole @default(MEMBER)
  joinedAt    DateTime      @default(now())

  community   Community     @relation(fields: [communityId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([communityId, userId])
}

enum CommunityRole {
  MEMBER
  MODERATOR
  ADMIN
  OWNER
}

model Announcement {
  id          String    @id @default(uuid())
  communityId String
  title       String
  content     String
  isPinned    Boolean   @default(false)
  createdAt   DateTime  @default(now())

  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
}

model Event {
  id          String    @id @default(uuid())
  communityId String
  title       String
  description String?
  location    String?
  latitude    Float?
  longitude   Float?
  startsAt    DateTime
  endsAt      DateTime?
  maxAttendees Int?
  createdAt   DateTime  @default(now())

  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
}

// ─── LISTINGS ───────────────────────────────────────────────────────────

model Listing {
  id              String       @id @default(uuid())
  communityId     String?
  creatorId       String
  type            ListingType
  title           String
  description     String?
  longDescription String?
  latitude        Float?
  longitude       Float?
  address         String?
  city            String?
  region          String?
  country         String?

  // Land-specific
  acreage         Float?
  soilType        String?
  waterAccess     Boolean?
  electricityAccess Boolean?
  roadAccess      Boolean?
  zoning          String?
  climate         String?

  // Resource-specific
  resourceCategory String?
  quantity        Int?
  condition       String?

  // Service-specific
  serviceCategory String?
  hourlyRate      Float?
  isRemote        Boolean?

  // Availability
  availableFrom   DateTime?
  availableTo     DateTime?
  isFlexible      Boolean     @default(true)

  // Exchange model
  exchangeType    ExchangeType @default(FLEXIBLE)
  priceAmount     Float?
  priceCurrency   String?      @default("USD")
  priceInterval   String?      // per_hour, per_day, per_month

  // Status
  status          ListingStatus @default(DRAFT)
  isActive        Boolean       @default(true)
  isFeatured      Boolean       @default(false)
  viewCount       Int           @default(0)
  tags            String[]      @default([])

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  community       Community?    @relation(fields: [communityId], references: [id])
  creator         User          @relation(fields: [creatorId], references: [id])
  images          ListingImage[]
  requests        Request[]
  savedBy         SavedListing[]
  reports         Report[]      @relation("ReportedListing")
}

enum ListingType {
  LAND
  RESOURCE
  SERVICE
}

enum ListingStatus {
  DRAFT
  PENDING_REVIEW
  ACTIVE
  PAUSED
  CLOSED
  ARCHIVED
}

enum ExchangeType {
  FREE
  TRADE
  PAID
  WORK_EXCHANGE
  DONATION
  FLEXIBLE
}

model ListingImage {
  id        String  @id @default(uuid())
  listingId String
  url       String
  caption   String?
  order     Int     @default(0)

  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

model SavedListing {
  id        String   @id @default(uuid())
  userId    String
  listingId String
  savedAt   DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
}

// ─── REQUESTS & MATCHES ────────────────────────────────────────────────

model Request {
  id          String        @id @default(uuid())
  listingId   String
  requesterId String
  message     String?
  status      RequestStatus @default(PENDING)
  proposedDates String?
  guestCount  Int?          @default(1)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  listing     Listing       @relation(fields: [listingId], references: [id])
  requester   User          @relation("Requester", fields: [requesterId], references: [id])
  match       Match?
  conversation Conversation?
}

enum RequestStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
  EXPIRED
  COMPLETED
}

model Match {
  id          String   @id @default(uuid())
  requestId   String   @unique
  communityId String?
  matchedAt   DateTime @default(now())
  completedAt DateTime?
  status      MatchStatus @default(ACTIVE)

  request     Request    @relation(fields: [requestId], references: [id])
  community   Community? @relation(fields: [communityId], references: [id])
  reviews     Review[]
  agreement   Agreement?
}

enum MatchStatus {
  ACTIVE
  COMPLETED
  CANCELLED
  DISPUTED
}

// ─── MESSAGING ──────────────────────────────────────────────────────────

model Conversation {
  id          String    @id @default(uuid())
  requestId   String?   @unique
  title       String?
  isArchived  Boolean   @default(false)
  lastMessageAt DateTime?
  createdAt   DateTime  @default(now())

  request     Request?  @relation(fields: [requestId], references: [id])
  messages    Message[]
  participants ConversationParticipant[]
}

model ConversationParticipant {
  id             String   @id @default(uuid())
  conversationId String
  userId         String
  lastReadAt     DateTime?
  joinedAt       DateTime @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
}

model Message {
  id             String   @id @default(uuid())
  conversationId String
  senderId       String
  content        String
  type           MessageType @default(TEXT)
  attachmentUrl  String?
  isEdited       Boolean  @default(false)
  isDeleted      Boolean  @default(false)
  sentAt         DateTime @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation("MessageSender", fields: [senderId], references: [id])
}

enum MessageType {
  TEXT
  IMAGE
  FILE
  SYSTEM
  REQUEST_UPDATE
}

// ─── TRUST & SAFETY ─────────────────────────────────────────────────────

model Review {
  id         String   @id @default(uuid())
  matchId    String
  authorId   String
  subjectId  String
  rating     Int      // 1-5
  comment    String?
  isPublic   Boolean  @default(true)
  helpfulCount Int    @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  match      Match    @relation(fields: [matchId], references: [id])
  author     User     @relation("ReviewAuthor", fields: [authorId], references: [id])
  subject    User     @relation("ReviewSubject", fields: [subjectId], references: [id])
}

model Verification {
  id         String             @id @default(uuid())
  userId     String
  type       VerificationType
  status     VerificationStatus @default(PENDING)
  metadata   Json?
  issuedAt   DateTime           @default(now())
  verifiedAt DateTime?
  expiresAt  DateTime?

  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum VerificationType {
  EMAIL
  PHONE
  ID_DOCUMENT
  SELFIE
  ADDRESS
  BACKGROUND_CHECK
  VIDEO_CALL
  SOCIAL_LINK
}

enum VerificationStatus {
  PENDING
  IN_REVIEW
  APPROVED
  REJECTED
  EXPIRED
}

model Agreement {
  id            String   @id @default(uuid())
  matchId       String   @unique
  title         String?
  terms         String?
  termsUrl      String?
  startDate     DateTime?
  endDate       DateTime?
  signedByHost  DateTime?
  signedByGuest DateTime?
  status        AgreementStatus @default(DRAFT)
  createdAt     DateTime @default(now())

  match         Match    @relation(fields: [matchId], references: [id])
}

enum AgreementStatus {
  DRAFT
  PENDING_SIGNATURES
  ACTIVE
  COMPLETED
  TERMINATED
}

model Report {
  id                  String       @id @default(uuid())
  reporterId          String
  reportedUserId      String?
  reportedCommunityId String?
  reportedListingId   String?
  type                ReportType
  reason              ReportReason
  message             String
  status              ReportStatus @default(PENDING)
  resolvedAt          DateTime?
  resolution          String?
  createdAt           DateTime     @default(now())

  reporter            User         @relation("Reporter", fields: [reporterId], references: [id])
  reportedUser        User?        @relation("ReportedUser", fields: [reportedUserId], references: [id])
  reportedCommunity   Community?   @relation("ReportedCommunity", fields: [reportedCommunityId], references: [id])
  reportedListing     Listing?     @relation("ReportedListing", fields: [reportedListingId], references: [id])
}

enum ReportType {
  USER
  COMMUNITY
  LISTING
  MESSAGE
}

enum ReportReason {
  SPAM
  HARASSMENT
  MISLEADING
  INAPPROPRIATE
  SAFETY_CONCERN
  FRAUD
  DISCRIMINATION
  OTHER
}

enum ReportStatus {
  PENDING
  UNDER_REVIEW
  RESOLVED
  DISMISSED
  ESCALATED
}

// ─── NOTIFICATIONS & INVITES ────────────────────────────────────────────

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  body      String?
  actionUrl String?
  metadata  Json?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum NotificationType {
  REQUEST_RECEIVED
  REQUEST_ACCEPTED
  REQUEST_REJECTED
  NEW_MESSAGE
  NEW_REVIEW
  LISTING_APPROVED
  COMMUNITY_INVITE
  VERIFICATION_UPDATE
  MATCH_COMPLETED
  SYSTEM
}

model Invite {
  id          String       @id @default(uuid())
  senderId    String
  recipientId String?
  email       String?
  communityId String?
  token       String       @unique @default(uuid())
  status      InviteStatus @default(PENDING)
  createdAt   DateTime     @default(now())
  expiresAt   DateTime

  sender      User         @relation("InviteSender", fields: [senderId], references: [id])
  recipient   User?        @relation("InviteRecipient", fields: [recipientId], references: [id])
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}
